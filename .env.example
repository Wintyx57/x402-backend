PORT=3000
NETWORK=mainnet
NODE_ENV=production
WALLET_ADDRESS=0xYourColdWalletAddress
WALLET_ID=optional-coinbase-wallet-id
COINBASE_API_KEY=your-cdp-api-key
COINBASE_API_SECRET=your-cdp-api-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
# Custom domain — update to match your production domain
FRONTEND_URL=https://x402bazaar.org

# Admin dashboard protection (required in production)
ADMIN_TOKEN=your-secret-admin-token

# Image generation (required for /api/image endpoint)
OPENAI_API_KEY=sk-...

# Demo agent (optional - only needed for demo-agent.js)
DEMO_SERVER_URL=https://x402-api.onrender.com

# Monitoring alerts (RECOMMENDED in production — all monitoring alerts and bot commands are
# silently disabled without these values)
# TELEGRAM_BOT_TOKEN=123456:ABCdefGhIjKlMnOpQrStUvWxYz
# TELEGRAM_CHAT_ID=123456789

# MCP Server (optional - only needed for mcp-server.mjs)
# Option A: Direct private key (recommended for new users)
# IMPORTANT: Never commit this value — use secret env vars on Render/CI in production
AGENT_PRIVATE_KEY=0xYourEthereumPrivateKey
# Option B: Coinbase SDK seed file (legacy)
# AGENT_SEED_PATH=agent-seed.json
# X402_SERVER_URL=https://x402-api.onrender.com
# MAX_BUDGET_USDC=1.00

# Community Agent (optional - companion process or remote service)
# For local dev: leave blank (spawned automatically)
# For remote service (Render): https://x402-community-agent.onrender.com
# COMMUNITY_AGENT_URL=https://x402-community-agent.onrender.com

# Set to 'true' to explicitly enable the community agent companion process
# ENABLE_COMMUNITY_AGENT=true

# Webhook URL exposed by the community agent (used by backend to forward events)
# COMMUNITY_AGENT_WEBHOOK_URL=https://x402-community-agent.onrender.com/api/webhook/new-api

# Timeout (ms) for requests proxied to the community agent (default: 5000)
# COMMUNITY_AGENT_TIMEOUT_MS=5000

# Keep-alive: external Render URL for self-ping every 10min (prevents free-tier spin-down)
# RENDER_EXTERNAL_URL=https://x402-api.onrender.com

# Per-wallet rate limit: max paid API calls per wallet per minute (default: unlimited)
# WALLET_RATE_LIMIT=60

# Daily E2E tester — performs REAL USDC payments on SKALE to test all services every 24h
# WARNING: requires a funded SKALE wallet (AGENT_PRIVATE_KEY) with USDC + CREDITS for gas
# ENABLE_DAILY_TESTER=true

# Auto-Faucet: distributes CREDITS (gas) to new wallets on SKALE on Base
# The faucet wallet must be funded with CREDITS on SKALE on Base (chain ID 1187947933)
# When set, setup_wallet auto-sends 0.01 CREDITS to wallets with 0 balance
# FAUCET_PRIVATE_KEY=0xYourFaucetWalletPrivateKey

# ERC-8004 agent identity (optional - used for agent-to-agent discovery)
# ERC8004_AGENT_ID=0xYourAgentIdentityAddress

# Polygon Facilitator (Phase 2) — optional, enables gas-free payments on Polygon
# When set, backend uses HTTP verification via facilitator instead of direct RPC (Phase 1).
# When absent, Polygon falls back transparently to Phase 1 (direct on-chain RPC verification).
# POLYGON_FACILITATOR_URL=https://x402.polygon.technology
# POLYGON_FEE_SPLITTER_CONTRACT=0x<DEPLOYED_FEE_SPLITTER_ADDRESS>

# FeeSplitter operator key — required to call distribute() after a facilitator payment.
# Must be the operator or owner of the FeeSplitter contract on Polygon mainnet.
# When absent, distribute() is skipped silently (USDC accumulates in the contract).
# IMPORTANT: Never commit this value — set it as a secret env var on Render.
# FEE_SPLITTER_OPERATOR_KEY=0xYourOperatorPrivateKey
